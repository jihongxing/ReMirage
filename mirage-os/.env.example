# Mirage-OS 环境变量配置示例

# 数据库配置
DB_HOST=localhost
DB_PORT=54329
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mirage_os

# gRPC 服务配置
GRPC_PORT=50847

# HTTP 服务配置
HTTP_PORT=18443

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=63791
REDIS_PASSWORD=
REDIS_DB=0

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json

# 计费配置
BASE_TRAFFIC_RATE=0.10
DEFENSE_TRAFFIC_RATE=0.05

# 威胁检测配置
THREAT_THRESHOLD=100
AUTO_ADJUST_DEFENSE=true

# Monero 配置
MONERO_RPC_URL=http://localhost:28081
MONERO_WALLET_RPC_URL=http://localhost:28083
MONERO_CONFIRMATIONS=10
MONERO_RPC_USER=mirage
MONERO_RPC_PASSWORD=your_secure_password_here
# View-Only 钱包配置 (用于只读监听入账)
MONERO_ADDRESS=4xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MONERO_VIEW_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT 配置
JWT_SECRET=change-this-in-production
JWT_EXPIRY=86400

# 环境
ENVIRONMENT=development

# ═══════════════════════════════════════════════════════════════
# 影子控制台配置 (Console)
# ═══════════════════════════════════════════════════════════════

# 监听地址（默认仅本地，生产环境通过 SSH 隧道访问）
CONSOLE_ADDR=127.0.0.1:8443

# TLS 证书（可选，不配置则 HTTP 明文仅本地）
CONSOLE_CERT=
CONSOLE_KEY=

# mTLS 客户端 CA（配置后启用双向认证，无客户端证书 → 400 Bad Request）
# 生成方式：
#   1. openssl genrsa -out admin-ca.key 4096
#   2. openssl req -new -x509 -key admin-ca.key -out admin-ca.crt -days 3650 -subj "/CN=Mirage Admin CA"
#   3. openssl genrsa -out admin.key 2048
#   4. openssl req -new -key admin.key -out admin.csr -subj "/CN=admin"
#   5. openssl x509 -req -in admin.csr -CA admin-ca.crt -CAkey admin-ca.key -CAcreateserial -out admin.crt -days 365
#   6. openssl pkcs12 -export -out admin.p12 -inkey admin.key -in admin.crt -certfile admin-ca.crt
#   7. 将 admin.p12 导入浏览器，CONSOLE_CLIENT_CA 指向 admin-ca.crt
CONSOLE_CLIENT_CA=
